CONFIG_TARGET_x86=y
CONFIG_TARGET_x86_64=y
CONFIG_TARGET_x86_64_DEVICE_generic=y
CONFIG_TARGET_ROOTFS_EXT4FS=y
CONFIG_TARGET_ROOTFS_SQUASHFS=y
CONFIG_TARGET_SQUASHFS_BLOCK_SIZE=256
CONFIG_TARGET_UBIFS_FREE_SPACE_FIXUP=y
CONFIG_TARGET_UBIFS_JOURNAL_SIZE=""
CONFIG_GRUB_EFI_IMAGES=y
CONFIG_QCOW2_IMAGES=y
CONFIG_VHDX_IMAGES=y
CONFIG_TARGET_IMAGES_GZIP=y
CONFIG_GRUB_TIMEOUT="0"
CONFIG_KERNEL_BUILD_USER="AlexY"
CONFIG_GRUB_TITLE="OpenWrt Build by AlexY"

# 固件大小
CONFIG_TARGET_KERNEL_PARTSIZE=64
CONFIG_TARGET_ROOTFS_PARTSIZE=1024

# 核心网络基础与 IPv6
CONFIG_PACKAGE_ipv6helper=y
CONFIG_PACKAGE_dnsmasq_full_dhcpv6=y
CONFIG_PACKAGE_6in4=y
CONFIG_PACKAGE_6rd=y
CONFIG_PACKAGE_6to4=y

CONFIG_PACKAGE_luci-app-turboacc=y

CONFIG_PACKAGE_luci-app-ddns=y
CONFIG_PACKAGE_wget-ssl=y
CONFIG_PACKAGE_curl=y
CONFIG_PACKAGE_ca-bundle=y
CONFIG_PACKAGE_ddns-scripts-cloudflare=y

# 基础运维与安全防护
CONFIG_PACKAGE_luci-app-uhttpd=y
CONFIG_PACKAGE_luci-app-beardropper=y
CONFIG_PACKAGE_luci-app-ntpc=y
CONFIG_PACKAGE_luci-app-wireguard=y
CONFIG_PACKAGE_luci-app-vlmcsd=y

# 核心网络代理（你补齐的 JMS 满血黄金组合）
CONFIG_PACKAGE_luci-app-ssr-plus=y
CONFIG_PACKAGE_luci-app-ssr-plus_INCLUDE_Shadowsocks_Rust_Client=y
CONFIG_PACKAGE_luci-app-ssr-plus_INCLUDE_Simple_Obfs=y
CONFIG_PACKAGE_luci-app-ssr-plus_INCLUDE_V2ray_Plugin=y
CONFIG_PACKAGE_luci-app-ssr-plus_INCLUDE_Xray=y
CONFIG_PACKAGE_luci-app-ssr-plus_INCLUDE_Http_Proxy=y

# 现代前端视觉底座
CONFIG_PACKAGE_luci-theme-bootstrap=y
CONFIG_PACKAGE_luci-theme-netgear=y

# =======================================================
# 🛡️ 核心审计拦截名单 (严防臃肿，死保 BBR 加速与代理独占)
# =======================================================
# 1. 性能互斥拦截 (抛弃 SQM，独尊 TurboACC)
# CONFIG_PACKAGE_luci-app-sqm is not set
# CONFIG_PACKAGE_sqm-scripts is not set
# CONFIG_PACKAGE_luci-app-qos is not set

# 2. 代理面板互斥拦截 (死保 SSR-Plus)
# CONFIG_PACKAGE_luci-app-passwall is not set
# CONFIG_PACKAGE_luci-app-openclash is not set
# CONFIG_PACKAGE_luci-app-homeproxy is not set

# 3. 臃肿业务及老旧协议拦截
# CONFIG_PACKAGE_autosamba is not set
# CONFIG_PACKAGE_samba36-server is not set
# CONFIG_PACKAGE_luci-app-samba is not set
# CONFIG_PACKAGE_coremark is not set
# CONFIG_PACKAGE_mwan3 is not set
# CONFIG_PACKAGE_luci-app-mwan3 is not set
